{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Component Inventory",
  "version": "0.1.0",
  "identifier": "com.bugragungoz.component-inventory",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Component Inventory",
        "width": 1400,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:component_inventory.db"]
    },
    "shell": {
      "open": true
    }
  }
}
